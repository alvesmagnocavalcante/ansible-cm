<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Status dos Servidores e VMs Windows</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0d12;
      --bg-panel: #12161d;
      --bg-panel-2: #171c24;
      --border: #232a35;
      --border-soft: #1b2129;
      --text: #e7ecf3;
      --text-muted: #7c8aa0;
      --text-dim: #4d5a6e;
      --accent: #4fd1c5;
      --accent-dim: #1f4d49;
      --ok: #3ddc97;
      --ok-bg: rgba(61, 220, 151, 0.12);
      --warning: #f5b94d;
      --warning-bg: rgba(245, 185, 77, 0.12);
      --critical: #f2646b;
      --critical-bg: rgba(242, 100, 107, 0.13);
      --font-display: 'Space Grotesk', 'Segoe UI', Arial, sans-serif;
      --font-body: 'Inter', 'Segoe UI', Arial, sans-serif;
      --font-mono: 'JetBrains Mono', 'Consolas', monospace;
    }

    * { box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      background:
        radial-gradient(1200px 500px at 15% -10%, rgba(79, 209, 197, 0.07), transparent 60%),
        var(--bg);
      color: var(--text);
      margin: 0;
      padding: 32px clamp(16px, 4vw, 48px) 64px;
      line-height: 1.5;
    }

    /* ---------- Header ---------- */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 12px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 20px;
      margin-bottom: 24px;
    }

    h1 {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 26px;
      letter-spacing: -0.01em;
      margin: 0 0 4px;
      color: var(--text);
    }

    .eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 6px;
    }

    .muted {
      color: var(--text-muted);
      font-size: 13px;
      font-family: var(--font-mono);
    }

    /* ---------- Summary strip ---------- */
    .summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(140px, 1fr));
      gap: 12px;
      margin: 0 0 32px;
    }

    .stat {
      background: var(--bg-panel);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 18px;
      position: relative;
      overflow: hidden;
    }

    .stat::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 100%;
      background: var(--stat-color, var(--text-dim));
    }

    .stat .num {
      font-family: var(--font-display);
      font-size: 30px;
      font-weight: 700;
      color: var(--stat-color, var(--text));
      display: block;
      line-height: 1;
    }

    .stat .label {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 6px;
      display: block;
    }

    .stat.stat-ok { --stat-color: var(--ok); }
    .stat.stat-critical { --stat-color: var(--critical); }
    .stat.stat-warning { --stat-color: var(--warning); }

    /* ---------- Host grid ---------- */
    .host-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
      gap: 18px;
    }

    .host-card {
      background: var(--bg-panel);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 22px 22px;
    }

    .host-card.offline {
      border: 1px dashed rgba(242, 100, 107, 0.45);
      background: linear-gradient(180deg, rgba(242, 100, 107, 0.05), transparent 40%), var(--bg-panel);
    }

    .host-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 14px;
    }

    .host-name {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 17px;
      margin: 0;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 4px 9px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .pill.ok { color: var(--ok); background: var(--ok-bg); }
    .pill.warning { color: var(--warning); background: var(--warning-bg); }
    .pill.critical { color: var(--critical); background: var(--critical-bg); }

    .dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: currentColor;
      flex: none;
    }

    @media (prefers-reduced-motion: no-preference) {
      .pill.ok .dot {
        animation: pulse 2s ease-in-out infinite;
      }
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(61, 220, 151, 0.5); }
      50% { box-shadow: 0 0 0 4px rgba(61, 220, 151, 0); }
    }

    /* ---------- Info grid inside card ---------- */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 20px;
      margin-bottom: 16px;
      font-size: 13px;
    }

    .info-grid dt {
      color: var(--text-muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0 0 2px;
    }

    .info-grid dd {
      margin: 0 0 10px;
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text);
    }

    /* ---------- Gauges ---------- */
    .gauge-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 16px;
    }

    .gauge-label {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 5px;
    }

    .gauge-label .value {
      font-family: var(--font-mono);
      color: var(--text);
      font-weight: 500;
    }

    .gauge-track {
      background: var(--bg-panel-2);
      border: 1px solid var(--border-soft);
      border-radius: 999px;
      height: 7px;
      overflow: hidden;
    }

    .gauge-fill {
      height: 100%;
      border-radius: 999px;
      background: var(--ok);
    }

    .gauge-fill.critical { background: var(--critical); }

    /* ---------- Section divider ---------- */
    .section-title {
      font-family: var(--font-mono);
      font-size: 10.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin: 16px 0 8px;
      padding-top: 12px;
      border-top: 1px solid var(--border-soft);
    }

    .section-title:first-of-type {
      border-top: none;
      padding-top: 0;
      margin-top: 0;
    }

    /* ---------- Security row ---------- */
    .security-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 4px;
    }

    .security-detail {
      font-size: 12px;
      color: var(--text-muted);
      margin: 6px 0 0;
      font-family: var(--font-mono);
    }

    .fw-profiles {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    .fw-chip {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 8px;
      border-radius: 6px;
      border: 1px solid var(--border);
      color: var(--text-muted);
    }

    .fw-chip.on { color: var(--ok); border-color: var(--accent-dim); }
    .fw-chip.off { color: var(--critical); border-color: rgba(242, 100, 107, 0.3); }

    /* ---------- Disks ---------- */
    .disk-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .disk-row {
      display: grid;
      grid-template-columns: 46px 1fr 90px;
      align-items: center;
      gap: 12px;
      font-size: 12px;
    }

    .disk-drive {
      font-family: var(--font-mono);
      font-weight: 600;
      color: var(--text);
    }

    .disk-meta {
      text-align: right;
      font-family: var(--font-mono);
      color: var(--text-muted);
      white-space: nowrap;
    }

    .disk-meta .pct.critical { color: var(--critical); }
    .disk-meta .pct.ok { color: var(--ok); }

    /* ---------- Offline card ---------- */
    .offline-body {
      font-size: 13px;
      color: var(--text-muted);
    }

    .offline-body .addr {
      font-family: var(--font-mono);
      color: var(--text);
    }

    @media (max-width: 720px) {
      .summary { grid-template-columns: repeat(2, 1fr); }
      .host-grid { grid-template-columns: 1fr; }
      .info-grid, .gauge-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <div class="page-header">
    <div>
      <p class="eyebrow">Monitoramento de infraestrutura</p>
      <h1>Status dos Servidores e VMs Windows</h1>
    </div>
    <div class="muted">Gerado em {{ ansible_facts['date_time']['date'] }} {{ ansible_facts['date_time']['time'] }} (controlador)</div>
  </div>

  <div class="summary">
    <div class="stat stat-ok">
      <span class="num">{{ heartbeat_online_hosts | length }}</span>
      <span class="label">online</span>
    </div>
    <div class="stat stat-critical">
      <span class="num">{{ heartbeat_offline_hosts | length }}</span>
      <span class="label">offline / sem coleta</span>
    </div>
    <div class="stat stat-warning">
      <span class="num">{{ heartbeat_alert_hosts | length }}</span>
      <span class="label">com alertas</span>
    </div>
    <div class="stat stat-warning">
      <span class="num">{{ heartbeat_defender_alert_hosts | length }}</span>
      <span class="label">alertas Defender/Firewall</span>
    </div>
  </div>

  <div class="host-grid">
  {% for host in heartbeat_hosts %}
    {% if hostvars[host].heartbeat_collection_ok | default(false) %}
      {% set d = hostvars[host].heartbeat_data %}
      <article class="host-card">
        <div class="host-head">
          <h2 class="host-name">{{ d.hostname | default(host) }}</h2>
          <span class="pill ok"><span class="dot"></span>Online</span>
        </div>

        <p class="section-title">Sistema</p>
        <dl class="info-grid">
          <div>
            <dt>Endereco</dt>
            <dd>{{ hostvars[host].ansible_host | default(host) }}</dd>
          </div>
          <div>
            <dt>Sistema</dt>
            <dd>{{ d.os }} {{ d.os_version }}</dd>
          </div>
          <div>
            <dt>Fabricante / modelo</dt>
            <dd>{{ d.manufacturer }} / {{ d.model }}</dd>
          </div>
          <div>
            <dt>Uptime</dt>
            <dd>{{ d.uptime_days }} dias (boot: {{ d.last_boot }})</dd>
          </div>
          <div>
            <dt>Servicos automaticos parados</dt>
            <dd>
              <span class="pill {{ 'warning' if d.stopped_automatic_services | int > 0 else 'ok' }}">{{ d.stopped_automatic_services }}</span>
            </dd>
          </div>
          <div>
            <dt>Coletado em</dt>
            <dd>{{ d.collected_at }}</dd>
          </div>
        </dl>

        <p class="section-title">Utilizacao</p>
        <div class="gauge-row">
          <div>
            <div class="gauge-label">
              <span>CPU</span>
              <span class="value">{{ d.cpu_percent }}%</span>
            </div>
            <div class="gauge-track">
              <div class="gauge-fill {{ 'critical' if d.cpu_percent | float >= cpu_warning_percent else '' }}" style="width: {{ d.cpu_percent }}%;"></div>
            </div>
          </div>
          <div>
            <div class="gauge-label">
              <span>Memoria</span>
              <span class="value">{{ d.memory_used_percent }}% de {{ d.memory_total_gb }} GB</span>
            </div>
            <div class="gauge-track">
              <div class="gauge-fill {{ 'critical' if d.memory_used_percent | float >= memory_warning_percent else '' }}" style="width: {{ d.memory_used_percent }}%;"></div>
            </div>
          </div>
        </div>

        <p class="section-title">Seguranca</p>
        <div class="security-row">
          <span class="pill {{ 'ok' if d.defender_status | default('') == 'Ativo' else 'critical' }}">
            <span class="dot"></span>Defender: {{ d.defender_status | default('Indisponivel', true) }}
          </span>
          <span class="pill {{ 'ok' if d.defender_realtime_enabled | default(false, true) else 'critical' }}">
            <span class="dot"></span>Tempo real: {{ 'Ativo' if d.defender_realtime_enabled | default(false, true) else 'Desativado' }}
          </span>
          <span class="pill {{ 'ok' if d.firewall_all_enabled | default(false, true) else 'critical' }}">
            <span class="dot"></span>Firewall: {{ d.firewall_status | default('Indisponivel', true) }}
          </span>
        </div>
        <p class="security-detail">
          Assinatura Defender: {{ d.defender_signature_age_days | default('-', true) }} dias
          {% if d.defender_error | default('-', true) != '-' %} &middot; Erro Defender: {{ d.defender_error }}{% endif %}
          {% if d.firewall_error | default('-', true) != '-' %} &middot; Erro Firewall: {{ d.firewall_error }}{% endif %}
        </p>
        <div class="fw-profiles">
          {% for profile in d.firewall_profiles | default([], true) %}
            <span class="fw-chip {{ 'on' if profile.enabled else 'off' }}">{{ profile.name }}: {{ 'Ativo' if profile.enabled else 'Desativado' }}</span>
          {% else %}
            <span class="fw-chip">Perfis indisponiveis</span>
          {% endfor %}
        </div>

        {% if d.disks | default([]) %}
        <p class="section-title">Discos</p>
        <div class="disk-list">
          {% for disk in d.disks | default([]) %}
          <div class="disk-row">
            <span class="disk-drive">{{ disk.drive }}</span>
            <div class="gauge-track">
              <div class="gauge-fill {{ 'critical' if disk.free_percent | float <= disk_warning_percent else '' }}" style="width: {{ disk.free_percent }}%;"></div>
            </div>
            <span class="disk-meta">
              {{ disk.free_gb }}/{{ disk.size_gb }} GB &middot;
              <span class="pct {{ 'critical' if disk.free_percent | float <= disk_warning_percent else 'ok' }}">{{ disk.free_percent }}%</span>
            </span>
          </div>
          {% endfor %}
        </div>
        {% endif %}
      </article>
    {% else %}
      <article class="host-card offline">
        <div class="host-head">
          <h2 class="host-name">{{ host }}</h2>
          <span class="pill critical"><span class="dot"></span>Offline</span>
        </div>
        <p class="offline-body">
          Endereco: <span class="addr">{{ hostvars[host].ansible_host | default(host) }}</span><br>
          Verifique rede, WinRM e credenciais.
        </p>
      </article>
    {% endif %}
  {% endfor %}
  </div>

</body>
</html>
