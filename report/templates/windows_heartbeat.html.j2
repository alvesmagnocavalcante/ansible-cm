<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="x-apple-disable-message-reformatting">
<title>Status dos Servidores e VMs Windows</title>
<style>
  body { margin:0; padding:0; background-color:#eef1f5; }
  table { border-collapse:collapse; }
  td { font-family:Arial, Helvetica, sans-serif; }
  img { border:0; }
  @media only screen and (max-width:600px) {
    .stack-col { display:block !important; width:100% !important; }
    .container { width:100% !important; }
  }
</style>
</head>
<body style="margin:0; padding:0; background-color:#eef1f5;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#eef1f5;">
<tr>
<td align="center" style="padding:24px 12px;">

<table role="presentation" width="640" class="container" cellpadding="0" cellspacing="0" style="width:640px; max-width:640px;">

  <!-- Header -->
  <tr>
    <td style="padding:4px 4px 18px;">
      <div style="font-family:'Courier New', Courier, monospace; font-size:11px; letter-spacing:1px; text-transform:uppercase; color:#0f766e; font-weight:bold;">Monitoramento de infraestrutura</div>
      <div style="font-family:Arial, Helvetica, sans-serif; font-size:22px; font-weight:bold; color:#1c2733; padding-top:2px;">Status dos Servidores e VMs Windows</div>
      <div style="font-family:'Courier New', Courier, monospace; font-size:12px; color:#667085; padding-top:6px;">Gerado em {{ ansible_facts['date_time']['date'] }} {{ ansible_facts['date_time']['time'] }} (controlador)</div>
    </td>
  </tr>

  <!-- Summary stats -->
  <tr>
    <td style="padding-bottom:20px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td width="25%" class="stack-col" style="padding:4px;">
            <table role="presentation" width="100%" height="72" cellpadding="0" cellspacing="0" style="background:#ffffff; border:1px solid #dde3ea; border-left:3px solid #0f9d6b;">
              <tr><td height="72" valign="middle" style="padding:12px 14px;">
                <div style="font-family:Arial; font-size:24px; font-weight:bold; color:#0f9d6b; line-height:1;">{{ heartbeat_online_hosts | length }}</div>
                <div style="font-family:Arial; font-size:11px; color:#667085; padding-top:4px; line-height:1.3;">online</div>
              </td></tr>
            </table>
          </td>
          <td width="25%" class="stack-col" style="padding:4px;">
            <table role="presentation" width="100%" height="72" cellpadding="0" cellspacing="0" style="background:#ffffff; border:1px solid #dde3ea; border-left:3px solid #c0392b;">
              <tr><td height="72" valign="middle" style="padding:12px 14px;">
                <div style="font-family:Arial; font-size:24px; font-weight:bold; color:#c0392b; line-height:1;">{{ heartbeat_offline_hosts | length }}</div>
                <div style="font-family:Arial; font-size:11px; color:#667085; padding-top:4px; line-height:1.3;">offline / sem coleta</div>
              </td></tr>
            </table>
          </td>
          <td width="25%" class="stack-col" style="padding:4px;">
            <table role="presentation" width="100%" height="72" cellpadding="0" cellspacing="0" style="background:#ffffff; border:1px solid #dde3ea; border-left:3px solid #b8860b;">
              <tr><td height="72" valign="middle" style="padding:12px 14px;">
                <div style="font-family:Arial; font-size:24px; font-weight:bold; color:#b8860b; line-height:1;">{{ heartbeat_alert_hosts | length }}</div>
                <div style="font-family:Arial; font-size:11px; color:#667085; padding-top:4px; line-height:1.3;">com alertas</div>
              </td></tr>
            </table>
          </td>
          <td width="25%" class="stack-col" style="padding:4px;">
            <table role="presentation" width="100%" height="72" cellpadding="0" cellspacing="0" style="background:#ffffff; border:1px solid #dde3ea; border-left:3px solid #b8860b;">
              <tr><td height="72" valign="middle" style="padding:12px 14px;">
                <div style="font-family:Arial; font-size:24px; font-weight:bold; color:#b8860b; line-height:1;">{{ heartbeat_defender_alert_hosts | length }}</div>
                <div style="font-family:Arial; font-size:11px; color:#667085; padding-top:4px; line-height:1.3;">alertas Defender/Firewall</div>
              </td></tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- Host cards -->
{% for host in heartbeat_hosts %}
  {% if hostvars[host].heartbeat_collection_ok | default(false) %}
    {% set d = hostvars[host].heartbeat_data %}
  <tr>
    <td style="padding-bottom:14px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff; border:1px solid #dde3ea;">

        <!-- card header -->
        <tr>
          <td style="padding:14px 18px; border-bottom:1px solid #eef1f5;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="font-family:Arial; font-size:16px; font-weight:bold; color:#1c2733;">{{ d.hostname | default(host) }}</td>
                <td align="right">
                  <span style="display:inline-block; padding:3px 10px; background:#e6f6ee; color:#0f9d6b; font-family:Arial; font-size:11px; font-weight:bold;">&#9679; ONLINE</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- system info -->
        <tr>
          <td style="padding:14px 18px 4px;">
            <div style="font-family:'Courier New', Courier, monospace; font-size:10.5px; letter-spacing:1px; text-transform:uppercase; color:#98a4b3; padding-bottom:6px;">Sistema</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-family:Arial; font-size:13px; color:#1c2733;">
              <tr>
                <td width="50%" style="padding:3px 8px 9px 0; vertical-align:top;">
                  <div style="font-size:11px; color:#667085;">Endereco</div>
                  <div style="font-family:'Courier New', Courier, monospace;">{{ hostvars[host].ansible_host | default(host) }}</div>
                </td>
                <td width="50%" style="padding:3px 0 9px 8px; vertical-align:top;">
                  <div style="font-size:11px; color:#667085;">Sistema</div>
                  <div>{{ d.os }} {{ d.os_version }}</div>
                </td>
              </tr>
              <tr>
                <td width="50%" style="padding:3px 8px 9px 0; vertical-align:top;">
                  <div style="font-size:11px; color:#667085;">Fabricante / modelo</div>
                  <div>{{ d.manufacturer }} / {{ d.model }}</div>
                </td>
                <td width="50%" style="padding:3px 0 9px 8px; vertical-align:top;">
                  <div style="font-size:11px; color:#667085;">Uptime</div>
                  <div>{{ d.uptime_days }} dias (boot: {{ d.last_boot }})</div>
                </td>
              </tr>
              <tr>
                <td width="50%" style="padding:3px 8px 9px 0; vertical-align:top;">
                  <div style="font-size:11px; color:#667085;">Servicos automaticos parados</div>
                  <div>
                    <span style="display:inline-block; padding:1px 8px; background:{{ '#fef6e7' if d.stopped_automatic_services | int > 0 else '#e6f6ee' }}; color:{{ '#b8860b' if d.stopped_automatic_services | int > 0 else '#0f9d6b' }}; font-family:Arial; font-size:12px; font-weight:bold;">{{ d.stopped_automatic_services }}</span>
                  </div>
                </td>
                <td width="50%" style="padding:3px 0 9px 8px; vertical-align:top;">
                  <div style="font-size:11px; color:#667085;">Coletado em</div>
                  <div style="font-family:'Courier New', Courier, monospace;">{{ d.collected_at }}</div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- utilization gauges -->
        <tr>
          <td style="padding:6px 18px 4px;">
            <div style="font-family:'Courier New', Courier, monospace; font-size:10.5px; letter-spacing:1px; text-transform:uppercase; color:#98a4b3; padding-bottom:6px;">Utilizacao</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td width="50%" style="padding-right:8px; vertical-align:top;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                    <tr>
                      <td style="font-family:Arial; font-size:12px; color:#667085;">CPU</td>
                      <td align="right" style="font-family:'Courier New', Courier, monospace; font-size:12px; color:#1c2733;">{{ d.cpu_percent }}%</td>
                    </tr>
                  </table>
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#eef1f5; margin-top:4px;">
                    <tr>
                      <td width="{{ d.cpu_percent }}%" style="background:{{ '#c0392b' if d.cpu_percent | float >= cpu_warning_percent else '#0f766e' }}; line-height:7px; font-size:1px;">&nbsp;</td>
                      <td style="line-height:7px; font-size:1px;">&nbsp;</td>
                    </tr>
                  </table>
                </td>
                <td width="50%" style="padding-left:8px; vertical-align:top;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                    <tr>
                      <td style="font-family:Arial; font-size:12px; color:#667085;">Memoria</td>
                      <td align="right" style="font-family:'Courier New', Courier, monospace; font-size:12px; color:#1c2733;">{{ d.memory_used_percent }}% de {{ d.memory_total_gb }} GB</td>
                    </tr>
                  </table>
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#eef1f5; margin-top:4px;">
                    <tr>
                      <td width="{{ d.memory_used_percent }}%" style="background:{{ '#c0392b' if d.memory_used_percent | float >= memory_warning_percent else '#0f766e' }}; line-height:7px; font-size:1px;">&nbsp;</td>
                      <td style="line-height:7px; font-size:1px;">&nbsp;</td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- security -->
        <tr>
          <td style="padding:10px 18px 4px;">
            <div style="font-family:'Courier New', Courier, monospace; font-size:10.5px; letter-spacing:1px; text-transform:uppercase; color:#98a4b3; padding-bottom:6px;">Seguranca</div>
            <span style="display:inline-block; padding:3px 9px; margin:0 6px 6px 0; background:{{ '#e6f6ee' if d.defender_status | default('') == 'Ativo' else '#fdecec' }}; color:{{ '#0f9d6b' if d.defender_status | default('') == 'Ativo' else '#c0392b' }}; font-family:Arial; font-size:11px; font-weight:bold;">&#9679; Defender: {{ d.defender_status | default('Indisponivel', true) }}</span>
            <span style="display:inline-block; padding:3px 9px; margin:0 6px 6px 0; background:{{ '#e6f6ee' if d.defender_realtime_enabled | default(false, true) else '#fdecec' }}; color:{{ '#0f9d6b' if d.defender_realtime_enabled | default(false, true) else '#c0392b' }}; font-family:Arial; font-size:11px; font-weight:bold;">&#9679; Tempo real: {{ 'Ativo' if d.defender_realtime_enabled | default(false, true) else 'Desativado' }}</span>
            <span style="display:inline-block; padding:3px 9px; margin:0 6px 6px 0; background:{{ '#e6f6ee' if d.firewall_all_enabled | default(false, true) else '#fdecec' }}; color:{{ '#0f9d6b' if d.firewall_all_enabled | default(false, true) else '#c0392b' }}; font-family:Arial; font-size:11px; font-weight:bold;">&#9679; Firewall: {{ 'Ativo' if d.firewall_all_enabled | default(false, true) else 'Desativado' }}</span>

            <div style="font-family:'Courier New', Courier, monospace; font-size:11.5px; color:#667085; padding-top:6px;">
              {{ d.firewall_status | default('Indisponivel', true) }}<br>
              Assinatura Defender: {{ d.defender_signature_age_days | default('-', true) }} dias &middot; Erro Defender: {{ d.defender_error | default('-', true) }} &middot; Erro Firewall: {{ d.firewall_error | default('-', true) }}
            </div>

            <div style="padding-top:8px;">
              {% for profile in d.firewall_profiles | default([], true) %}
                <span style="display:inline-block; padding:2px 8px; margin:0 6px 6px 0; border:1px solid {{ '#c7e8d9' if profile.enabled else '#f3caca' }}; color:{{ '#0f9d6b' if profile.enabled else '#c0392b' }}; font-family:'Courier New', Courier, monospace; font-size:11px;">{{ profile.name }}: {{ 'Ativo' if profile.enabled else 'Desativado' }}</span>
              {% else %}
                <span style="display:inline-block; padding:2px 8px; border:1px solid #dde3ea; color:#667085; font-family:'Courier New', Courier, monospace; font-size:11px;">Perfis indisponiveis</span>
              {% endfor %}
            </div>
          </td>
        </tr>

        <!-- disks -->
        {% if d.disks | default([]) %}
        <tr>
          <td style="padding:10px 18px 16px;">
            <div style="font-family:'Courier New', Courier, monospace; font-size:10.5px; letter-spacing:1px; text-transform:uppercase; color:#98a4b3; padding-bottom:6px;">Discos</div>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              {% for disk in d.disks | default([]) %}
              <tr>
                <td width="34" style="font-family:Arial; font-size:12px; font-weight:bold; color:#1c2733; vertical-align:middle; padding:3px 8px 3px 0;">{{ disk.drive }}</td>
                <td style="vertical-align:middle; padding:3px 0;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#eef1f5;">
                    <tr>
                      <td width="{{ disk.free_percent }}%" style="background:{{ '#c0392b' if disk.free_percent | float <= disk_warning_percent else '#0f766e' }}; line-height:7px; font-size:1px;">&nbsp;</td>
                      <td style="line-height:7px; font-size:1px;">&nbsp;</td>
                    </tr>
                  </table>
                </td>
                <td width="130" align="right" style="font-family:'Courier New', Courier, monospace; font-size:11.5px; color:{{ '#c0392b' if disk.free_percent | float <= disk_warning_percent else '#667085' }}; padding:3px 0 3px 8px; white-space:nowrap;">{{ disk.free_gb }}/{{ disk.size_gb }} GB &middot; {{ disk.free_percent }}%</td>
              </tr>
              {% endfor %}
            </table>
          </td>
        </tr>
        {% endif %}

      </table>
    </td>
  </tr>
  {% else %}
  <tr>
    <td style="padding-bottom:14px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fffaf9; border:1px dashed #e6a3a0;">
        <tr>
          <td style="padding:14px 18px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="font-family:Arial; font-size:16px; font-weight:bold; color:#1c2733;">{{ host }}</td>
                <td align="right">
                  <span style="display:inline-block; padding:3px 10px; background:#fdecec; color:#c0392b; font-family:Arial; font-size:11px; font-weight:bold;">&#9679; OFFLINE</span>
                </td>
              </tr>
            </table>
            <div style="font-family:Arial; font-size:13px; color:#667085; padding-top:8px;">
              Endereco: <span style="font-family:'Courier New', Courier, monospace; color:#1c2733;">{{ hostvars[host].ansible_host | default(host) }}</span><br>
              Verifique rede, WinRM e credenciais.
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  {% endif %}
{% endfor %}

  <!-- footer -->
  <tr>
    <td style="padding:8px 4px 4px; font-family:Arial; font-size:11px; color:#98a4b3;">
      Relatorio automatico gerado pelo Ansible.
    </td>
  </tr>

</table>

</td>
</tr>
</table>
</body>
</html>
